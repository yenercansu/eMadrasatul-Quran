{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev": "pnpm --filter @workspace/quran-app run start",
    "dev:android": "pnpm --filter @workspace/quran-app run android",
    "dev:ios": "pnpm --filter @workspace/quran-app run ios",
    "dev:web": "pnpm --filter @workspace/quran-app run web"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  }
}
